rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // All game data is public read-only. Writes come from Admin SDK (Cloud Functions)
    // which bypasses rules entirely.
    match /{document=**} {
      allow read;
      allow write: if false;
    }

    // Allow users to submit contact messages
    match /contacts/{contactId} {
      allow create: if request.resource.data.keys().hasOnly(['email', 'message', 'date'])
        && request.resource.data.message is string
        && request.resource.data.message.size() > 0
        && request.resource.data.message.size() <= 2000;
    }

    // Allow users to submit game search requests ("Add this game")
    match /searches/{searchId} {
      allow create: if request.resource.data.keys().hasOnly(['term', 'completed', 'date'])
        && request.resource.data.completed == false
        && request.resource.data.term is string
        && request.resource.data.term.size() > 0
        && request.resource.data.term.size() <= 200;
    }
  }
}
